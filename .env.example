# Copy to .env on the QNAP. Values below are the working defaults for the
# current homelab; edit if anything moves.

# Host that the browser uses to reach apps. Tile links point here.
PORTAL_EXTERNAL_HOST=http://10.5.251.8

# GID of the host's docker group. Find with:
#   stat -c '%g' /var/run/docker.sock
# On this QNAP the socket is owned by root:root (GID 0), so the container's
# appuser is added to group 0 to read it.
DOCKER_GID=0

# Shared docker network with the other homelab apps (vault, FMR, FML).
HOMELAB_DOCKER_NETWORK=homelab
